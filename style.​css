/* style.css */
@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap');

* { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Poppins', sans-serif; }
body { background-color: #0c0c0d; color: #f9f9f9; padding-bottom: 90px; }

/* Header Fix */
header { 
    padding: 15px 20px; 
    display: flex; 
    justify-content: space-between; 
    align-items: center; 
    position: sticky; 
    top: 0; 
    background: #0c0c0d; 
    z-index: 1000; 
}
.page-title { font-size: 18px; font-weight: 700; color: #fff; text-transform: uppercase; letter-spacing: 1px; }
.header-icons { font-size: 20px; color: #fdd835; }

/* Scream 7 Hero Section */
.hero-banner {
    width: 92%; margin: 10px auto;
    height: 400px; border-radius: 25px;
    background: linear-gradient(to top, #0c0c0d, transparent), url('https://ntvb.tmsimg.com/assets/p28448171_v_h8_ad.jpg?w=1280&h=720');
    background-size: cover; background-position: center;
    display: flex; flex-direction: column; justify-content: flex-end; padding: 20px;
    border: 1px solid rgba(255,255,255,0.1);
}
.hero-banner h1 { font-size: 24px; margin-bottom: 5px; }
.hero-banner p { font-size: 12px; color: #bbb; margin-bottom: 15px; }

/* Category Buttons (Disney+ style) */
.category-row {
    display: flex; gap: 10px; padding: 20px; overflow-x: auto;
    scrollbar-width: none;
}
.cat-card {
    min-width: 100px; height: 60px; background: #1a1b1c;
    border-radius: 12px; border: 1px solid #333;
    display: flex; align-items: center; justify-content: center;
    font-weight: 600; font-size: 13px; transition: 0.3s;
}
.cat-card:hover { border-color: #fdd835; background: #252627; }

/* Movie Grid Fix (ပုံတွေအကြီးကြီးမဖြစ်အောင်) */
.section-title { padding: 0 20px; font-size: 18px; margin-bottom: 15px; }
.movie-grid {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: 15px; padding: 0 20px;
}
.movie-card {
    background: #1a1b1c; border-radius: 18px; overflow: hidden;
    text-decoration: none; color: #fff; border: 1px solid #2a2b2c;
}
.movie-card img { width: 100%; height: 180px; object-fit: cover; }
.movie-info { padding: 12px; }
.movie-info h3 { font-size: 13px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.rating { font-size: 11px; color: #fdd835; margin-top: 5px; display: flex; align-items: center; gap: 4px; }

/* Navigation Bar */
nav {
    position: fixed; bottom: 15px; left: 50%; transform: translateX(-50%);
    width: 90%; max-width: 400px; height: 65px;
    background: rgba(20, 21, 22, 0.9); backdrop-filter: blur(15px);
    border-radius: 30px; display: flex; justify-content: space-around;
    align-items: center; border: 1px solid rgba(255,255,255,0.1); z-index: 2000;
}
nav a { color: #666; text-decoration: none; text-align: center; font-size: 20px; transition: 0.3s; }
nav a span { display: block; font-size: 10px; margin-top: 2px; }
nav a.active { color: #fdd835; }

/* Profile Page Specific */
.profile-box { text-align: center; padding: 30px 0; }
.avatar-circle {
    width: 100px; height: 100px; border-radius: 50%;
    border: 3px solid #fdd835; margin: 0 auto 15px;
    background: #222; overflow: hidden;
}
.avatar-circle img { width: 100%; height: 100%; object-fit: cover; }
.menu-list { width: 90%; margin: 0 auto; background: #1a1b1c; border-radius: 20px; padding: 10px; }
.menu-item {
    display: flex; justify-content: space-between; align-items: center;
    padding: 15px; border-bottom: 1px solid #2a2b2c; color: #fff; text-decoration: none;
}
.menu-item:last-child { border: none; }
