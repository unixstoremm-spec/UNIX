/* style.css */
@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap');

* { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Poppins', sans-serif; }
body { background-color: #0c0c0d; color: #f9f9f9; padding-bottom: 110px; overflow-x: hidden; }

/* --- Navigation Bar (ငြိမ်နေစေရန် ပုံသေထားသည်) --- */
nav {
    position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%);
    width: 90%; max-width: 400px;
    background: rgba(20, 21, 22, 0.95);
    backdrop-filter: blur(10px);
    height: 70px; border-radius: 35px;
    display: flex; justify-content: space-around; align-items: center;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    z-index: 2000; border: 1px solid rgba(255,255,255,0.1);
}
nav a { color: #666; text-decoration: none; display: flex; flex-direction: column; align-items: center; width: 60px; transition: 0.3s; }
nav a i { font-size: 20px; margin-bottom: 4px; }
nav a span { font-size: 10px; font-weight: 500; }
nav a.active { color: #fdd835; }

/* --- Global Header --- */
header { padding: 25px 20px; display: flex; justify-content: space-between; align-items: center; background: #0c0c0d; position: sticky; top: 0; z-index: 1000; }
.back-btn, .notification-btn { color: #f9f9f9; font-size: 20px; text-decoration: none; position: relative; }
.page-title { font-size: 18px; font-weight: 600; text-align: center; flex-grow: 1; }
.badge { position: absolute; top: -2px; right: -2px; width: 8px; height: 8px; background: #E21B23; border-radius: 50%; border: 1px solid #0c0c0d; }

/* --- Home Page Styles --- */
.featured-card {
    width: 100%; height: 450px; border-radius: 30px; margin-bottom: 30px;
    background: linear-gradient(to top, #0c0c0d 15%, transparent 70%), url('https://ntvb.tmsimg.com/assets/p28448171_v_h8_ad.jpg?w=1280&h=720');
    background-size: cover; background-position: center;
    display: flex; flex-direction: column; justify-content: flex-end; padding: 25px;
    border: 1px solid rgba(255,255,255,0.08);
}
.movie-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px; padding: 0 20px; }
.movie-card { background: #121314; border-radius: 20px; overflow: hidden; text-decoration: none; color: inherit; border: 1px solid rgba(255,255,255,0.05); transition: 0.3s; }
.movie-card:hover { border-color: #fdd835; transform: translateY(-3px); }
.movie-card img { width: 100%; height: 200px; object-fit: cover; }
.movie-info { padding: 12px; }
.movie-info h3 { font-size: 13px; margin-bottom: 5px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.movie-details { color: #888; font-size: 11px; display: flex; align-items: center; gap: 5px; }
.movie-details i { color: #fdd835; }

/* --- Profile Page Styles --- */
.profile-header { display: flex; flex-direction: column; align-items: center; padding: 20px 0; }
.avatar-box { width: 110px; height: 110px; border-radius: 50%; border: 2px solid #fdd835; position: relative; margin-bottom: 15px; }
.avatar-box img { width: 100%; height: 100%; border-radius: 50%; object-fit: cover; }
.cam-icon { position: absolute; bottom: 5px; right: 0; background: #fdd835; color: #000; width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; border: 3px solid #0c0c0d; }
.stats-row { display: flex; gap: 35px; margin: 20px 0; }
.stat-box { text-align: center; }
.stat-box h5 { color: #fdd835; font-size: 18px; }
.stat-box p { color: #666; font-size: 11px; }

.menu-container { padding: 0 20px; }
.menu-group { background: #121314; border-radius: 20px; margin-bottom: 20px; border: 1px solid rgba(255,255,255,0.05); }
.menu-item { display: flex; align-items: center; padding: 18px 20px; text-decoration: none; color: #fff; border-bottom: 1px solid rgba(255,255,255,0.03); }
.menu-item:last-child { border-bottom: none; }
.menu-icon { width: 35px; color: #fdd835; font-size: 18px; }
.menu-text { flex-grow: 1; font-size: 14px; }
